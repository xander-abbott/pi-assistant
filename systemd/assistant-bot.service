[Unit]
Description=Productivity Assistant Bot
After=network-online.target
Wants=network-online.target

[Service]
User=xanderabbott
WorkingDirectory=/home/xanderabbott/assistant
ExecStart=/home/xanderabbott/assistant/venv/bin/python bot.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
